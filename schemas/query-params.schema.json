{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/query-params.schema.json",
  "title": "AI Analysis Query Params",
  "type": "object",
  "required": ["schema_version", "source"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "source": {
      "type": "string",
      "enum": ["ga4", "gsc", "aa", "bigquery"]
    }
  },
  "$defs": {
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "transform": { "type": "string" },
        "where": { "type": "string" },
        "sort": { "type": "string" },
        "columns": { "type": "string" },
        "group_by": { "type": "string" },
        "aggregate": { "type": "string" },
        "head": { "type": "integer", "minimum": 1 }
      }
    },
    "save": {
      "type": "object",
      "required": ["to"],
      "additionalProperties": false,
      "properties": {
        "to": { "type": "string", "enum": ["csv", "sheets", "bigquery"] },
        "mode": { "type": "string", "enum": ["overwrite", "append", "upsert"], "default": "overwrite" },
        "path": { "type": "string" },
        "sheet_url": { "type": "string" },
        "sheet_name": { "type": "string", "default": "data" },
        "project_id": { "type": "string" },
        "dataset": { "type": "string" },
        "table": { "type": "string" },
        "keys": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "column_types": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": ["date", "int", "float", "currency", "percent", "text"]
      }
    },
    "json_object_or_array": {
      "oneOf": [
        {
          "type": "object"
        },
        {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "source": { "const": "ga4" }
        }
      },
      "then": {
        "type": "object",
        "required": ["schema_version", "source", "property_id", "date_range", "dimensions", "metrics"],
        "properties": {
          "schema_version": { "type": "string", "const": "1.0" },
          "source": { "type": "string", "const": "ga4" },
          "property_id": { "type": "string", "minLength": 1 },
          "date_range": {
            "type": "object",
            "required": ["start", "end"],
            "additionalProperties": false,
            "properties": {
              "start": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
              "end": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
            }
          },
          "dimensions": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "metrics": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "filter_d": { "type": "string" },
          "limit": { "type": "integer", "minimum": 1, "maximum": 100000 },
          "column_types": { "$ref": "#/$defs/column_types" },
          "pipeline": { "$ref": "#/$defs/pipeline" },
          "save": { "$ref": "#/$defs/save" }
        },
        "additionalProperties": false
      }
    },
    {
      "if": {
        "properties": {
          "source": { "const": "gsc" }
        }
      },
      "then": {
        "type": "object",
        "required": ["schema_version", "source", "site_url", "date_range", "dimensions"],
        "properties": {
          "schema_version": { "type": "string", "const": "1.0" },
          "source": { "type": "string", "const": "gsc" },
          "site_url": { "type": "string", "minLength": 1 },
          "date_range": {
            "type": "object",
            "required": ["start", "end"],
            "additionalProperties": false,
            "properties": {
              "start": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
              "end": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
            }
          },
          "dimensions": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "filter": { "type": "string" },
          "limit": { "type": "integer", "minimum": 1, "maximum": 100000 },
          "column_types": { "$ref": "#/$defs/column_types" },
          "pipeline": { "$ref": "#/$defs/pipeline" },
          "save": { "$ref": "#/$defs/save" }
        },
        "additionalProperties": false
      }
    },
    {
      "if": {
        "properties": {
          "source": { "const": "aa" }
        }
      },
      "then": {
        "type": "object",
        "required": ["schema_version", "source", "company_id", "rsid", "date_range", "dimension", "metrics"],
        "properties": {
          "schema_version": { "type": "string", "const": "1.0" },
          "source": { "type": "string", "const": "aa" },
          "site": { "type": "string", "minLength": 1 },
          "company_id": { "type": "string", "minLength": 1 },
          "org_id": { "type": "string", "minLength": 1 },
          "rsid": { "type": "string", "minLength": 1 },
          "date_range": {
            "type": "object",
            "required": ["start", "end"],
            "additionalProperties": false,
            "properties": {
              "start": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
              "end": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
            }
          },
          "dimension": { "type": "string", "minLength": 1 },
          "metrics": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "segment": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            ]
          },
          "segment_definition": { "$ref": "#/$defs/json_object_or_array" },
          "breakdown": { "$ref": "#/$defs/json_object_or_array" },
          "limit": { "type": "integer", "minimum": 1, "maximum": 100000 },
          "column_types": { "$ref": "#/$defs/column_types" },
          "pipeline": { "$ref": "#/$defs/pipeline" },
          "save": { "$ref": "#/$defs/save" }
        },
        "additionalProperties": false
      }
    },
    {
      "if": {
        "properties": {
          "source": { "const": "bigquery" }
        }
      },
      "then": {
        "type": "object",
        "required": ["schema_version", "source", "project_id", "sql"],
        "properties": {
          "schema_version": { "type": "string", "const": "1.0" },
          "source": { "type": "string", "const": "bigquery" },
          "project_id": { "type": "string", "minLength": 1 },
          "sql": { "type": "string", "minLength": 1 },
          "column_types": { "$ref": "#/$defs/column_types" },
          "pipeline": { "$ref": "#/$defs/pipeline" },
          "save": { "$ref": "#/$defs/save" }
        },
        "additionalProperties": false
      }
    }
  ]
}
